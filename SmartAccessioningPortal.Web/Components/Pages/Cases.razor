@page "/cases"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using SmartAccessioningPortal.Web.Models
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<h3>Intake Cases</h3>

@if (CaseList is not null)
{
    <div style="margin-bottom:20px;">
        <button class="btn btn-outline-secondary me-2" @onclick="@(() => SelectedStatus = "All")">
            All
        </button>

        <button class="btn btn-outline-warning me-2" @onclick="@(() => SelectedStatus = "Draft")">
            Draft
        </button>

        <button class="btn btn-outline-success" @onclick="@(() => SelectedStatus = "ReadyForReview")">
            Ready For Review
        </button>
        <div style="margin-bottom:20px;">
            <input class="form-control"
                   placeholder="Search by Case ID, status, test type, or created by..."
                   @bind="SearchText"
                   @bind:event="oninput" />
        </div>
    </div>

}


@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <p style="color:red">@ErrorMessage</p>
}

@if (CaseList is null)
{
    <p>Loading cases...</p>
}
else if (!FilteredCases.Any())
{
    <p>No cases found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Case ID</th>
                <th>Status</th>
                <th>Test Type</th>
                <th>Created By</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in FilteredCases)
            {
                <tr>
                    <td>
                        <a href="@($"/cases/{item.CaseId}")">@item.CaseId</a>
                    </td>
                    <td>
                        <span style="@GetStatusBadgeStyle(item.Status)">
                            @item.Status
                        </span>
                    </td>
                    <td>@item.TestType</td>
                    <td>@item.CreatedBy</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CaseListItemModel>? CaseList;
    private string? ErrorMessage;
    private string SearchText { get; set; } = string.Empty;


    private string SelectedStatus = "All";

    private IEnumerable<CaseListItemModel> FilteredCases
    {
        get
        {
            var query = CaseList ?? [];

            if (SelectedStatus != "All")
            {
                query = query.Where(x => x.Status == SelectedStatus).ToList();
            }

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                query = query.Where(x =>
                    x.CaseId.ToString().Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                    x.Status.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                    (x.TestType != null && x.TestType.Contains(SearchText, StringComparison.OrdinalIgnoreCase)) ||
                    x.CreatedBy.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
                ).ToList();
            }

            return query;
        }
    }

    private string GetStatusBadgeStyle(string status)
    {
        return status switch
        {
            "ReadyForReview" => "background-color:#d1e7dd; color:#0f5132; padding:4px 8px; border-radius:8px;",
            "Draft" => "background-color:#fff3cd; color:#664d03; padding:4px 8px; border-radius:8px;",
            _ => "background-color:#e2e3e5; color:#41464b; padding:4px 8px; border-radius:8px;"
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            CaseList = await client.GetFromJsonAsync<List<CaseListItemModel>>("api/cases");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading cases: {ex.Message}";
        }
    }
}