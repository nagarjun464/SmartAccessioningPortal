@page "/cases/new"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using SmartAccessioningPortal.Web.Models
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

<h3>New Intake Case</h3>

@if (ShowPreviewModal)
{
    <div style="
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(0,0,0,0.6);
                z-index: 2000;
                display: flex;
                align-items: center;
                justify-content: center;">

        <div style="
                    background-color: white;
                    width: 80%;
                    height: 85%;
                    border-radius: 8px;
                    padding: 15px;
                    display: flex;
                    flex-direction: column;">

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                <h4 style="margin:0;">Requisition Preview</h4>

                <button type="button"
                        class="btn btn-sm btn-danger"
                        @onclick="ClosePdfPreview">
                    Close
                </button>
            </div>

            <iframe src="@PreviewDocumentUrl"
                    style="width:100%; height:100%; border:1px solid #ccc;">
            </iframe>
        </div>
    </div>
}

@if (ShowToast)
{
    <div style="
            position: fixed;
            top: 20px;
            right: 20px;
            background-color: @ToastBackgroundColor;
            color: white;
            padding: 12px 20px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 10px;">

        <span>@ToastMessage</span>

        <button @onclick="CloseToast"
                style="
                        background: transparent;
                        border: none;
                        color: white;
                        font-size: 18px;
                        cursor: pointer;">
            ✖
        </button>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <p>@StatusMessage</p>
}

<EditForm Model="FormModel" OnValidSubmit="HandleSubmit" FormName="NewCaseForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <h4>Case Information</h4>
    <div>
        <label>Created By:</label><br />
        <InputText @bind-Value="FormModel.CreatedBy" />
    </div>
    <div>
        <label>Test Type:</label><br />
        <InputText @bind-Value="FormModel.TestType" />
    </div>

    <h4>Patient Information</h4>
    <div>
        <label>First Name:</label><br />
        <InputText @bind-Value="FormModel.FirstName" />
    </div>
    <div>
        <label>Last Name:</label><br />
        <InputText @bind-Value="FormModel.LastName" />
    </div>
    <div>
        <label>DOB:</label><br />
        <InputDate @bind-Value="FormModel.DOB" />
    </div>
    <div>
        <label>MRN:</label><br />
        <InputText @bind-Value="FormModel.MRN" />
    </div>

    <h4>Kit Information</h4>
    <div>
        <label>Kit Box Code:</label><br />
        <InputText @bind-Value="FormModel.KitBoxCode" />
    </div>
    <div>
        <label>Lot Code:</label><br />
        <InputText @bind-Value="FormModel.LotCode" />
    </div>
    <div>
        <label>Operator Name:</label><br />
        <InputText @bind-Value="FormModel.OperatorName" />
    </div>
    <div>
        <label>Received At:</label><br />
        <InputDate @bind-Value="FormModel.ReceivedAt" />
    </div>
    <h4>Requisition Upload</h4>

    <div>
        <label>Upload Requisition PDF/Image:</label><br />
        <InputFile id="reqFileInput"
                   OnChange="HandleFileSelected"
                   accept="application/pdf" />
        <button type="button"
                class="btn btn-sm btn-primary"
                @onclick="ShowPdfPreview">
            Preview Document
        </button>  
    </div>
    <div style="margin-top:10px;">
        <input type="checkbox" @bind="IsDocumentVerified" />
        <label>I confirm this is the correct requisition document</label>
    </div>

    @if (!string.IsNullOrWhiteSpace(SelectedFileName))
    {
        <p>Selected file: @SelectedFileName</p>
    }
    <br />
    <button type="submit">Save Intake Case</button>
</EditForm>

@code {
    private IntakeFormModel FormModel { get; set; } = new();
    private string? StatusMessage;
    private IBrowserFile? SelectedFile;
    private string? SelectedFileName;
    private bool ShowToast = false;
    private string ToastMessage = string.Empty;
    private string ToastBackgroundColor = "#198754";
    private bool ShowPreviewModal;
    private string? PreviewDocumentUrl;
    private bool IsDocumentVerified;

    private async Task ShowPdfPreview()
    {
        if (string.IsNullOrWhiteSpace(PreviewDocumentUrl))
        {
            await ShowErrorToast("No document selected for preview.");
            return;
        }

        ShowPreviewModal = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClosePdfPreview()
    {
        ShowPreviewModal = false;

        if (!string.IsNullOrWhiteSpace(PreviewDocumentUrl))
        {
            await JSRuntime.InvokeVoidAsync("pdfPreview.revokeUrl", PreviewDocumentUrl);
        }
    }
    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file.ContentType != "application/pdf")
        {
            SelectedFile = null;
            SelectedFileName = null;
            PreviewDocumentUrl = null;
            IsDocumentVerified = false;

            await ShowErrorToast("Only PDF files are allowed.");
            return;
        }

        SelectedFile = file;
        SelectedFileName = file.Name;
        IsDocumentVerified = false;

        PreviewDocumentUrl = await JSRuntime.InvokeAsync<string?>(
            "pdfPreview.createUrl",
            "reqFileInput");
    }

    private void CloseToast()
    {
        ShowToast = false;
    }

    private async Task ShowSuccessToast(string message)
    {
        ToastBackgroundColor = "#198754";
        await ShowToastMessage(message);
    }

    private async Task ShowErrorToast(string message)
    {
        ToastBackgroundColor = "#dc3545";
        await ShowToastMessage(message);
    }

    private async Task ShowToastMessage(string message)
    {
        ToastMessage = message;
        ShowToast = true;

        StateHasChanged();

        await Task.Delay(5000);

        if (ShowToast)
        {
            ShowToast = false;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {

        try
        {
            if (SelectedFile != null && !IsDocumentVerified)
            {
                await ShowErrorToast("Please preview and verify the uploaded document before submitting.");
                return;
            }
            var client = HttpClientFactory.CreateClient("ApiClient");

            var caseResponse = await client.PostAsJsonAsync("api/cases", new
            {
                FormModel.CreatedBy,
                FormModel.TestType
            });

            caseResponse.EnsureSuccessStatusCode();

            var createdCase = await caseResponse.Content.ReadFromJsonAsync<CaseResponseModel>();

            if (createdCase is null)
            {
                StatusMessage = "Failed to create case.";
                return;
            }

            var patientResponse = await client.PostAsJsonAsync(
                $"api/cases/{createdCase.CaseId}/patient",
                new
                {
                    FormModel.FirstName,
                    FormModel.LastName,
                    FormModel.DOB,
                    FormModel.MRN
                });

            patientResponse.EnsureSuccessStatusCode();

            var kitResponse = await client.PostAsJsonAsync(
                $"api/cases/{createdCase.CaseId}/kit-info",
                new
                {
                    FormModel.KitBoxCode,
                    FormModel.LotCode,
                    FormModel.OperatorName,
                    FormModel.ReceivedAt
                });

            kitResponse.EnsureSuccessStatusCode();
            if (SelectedFile is not null)
            {
                using var content = new MultipartFormDataContent();

                var fileContent = new StreamContent(SelectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
                fileContent.Headers.ContentType =
                    new System.Net.Http.Headers.MediaTypeHeaderValue(SelectedFile.ContentType);

                content.Add(fileContent, "file", SelectedFile.Name);

                var uploadResponse = await client.PostAsync(
                    $"api/cases/{createdCase.CaseId}/documents",
                    content);

                uploadResponse.EnsureSuccessStatusCode();
            }
            var submittedCaseId = createdCase.CaseId;
            var statusResponse = await client.PatchAsJsonAsync(
                    $"api/cases/{createdCase.CaseId}/status",
                    "ReadyForReview");

            statusResponse.EnsureSuccessStatusCode();

            PreviewDocumentUrl = null;
            IsDocumentVerified = false;
            ShowPreviewModal = false;
            FormModel = new IntakeFormModel();
            SelectedFile = null;
            SelectedFileName = null;

            await ShowSuccessToast($"Case {submittedCaseId} created successfully");
        }

        catch (Exception ex)
        {
            await ShowErrorToast($"Error: {ex.Message}");
        }
    }

    public class CaseResponseModel
    {
        public int CaseId { get; set; }
        public string Status { get; set; } = string.Empty;
        public string? TestType { get; set; }
        public DateTime CreatedAt { get; set; }
        public string CreatedBy { get; set; } = string.Empty;
    }
}